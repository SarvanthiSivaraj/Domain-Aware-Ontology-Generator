<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/ontology/cybersecurity"
         xmlns="http://example.org/ontology/cybersecurity#">

<owl:Ontology rdf:about="http://example.org/ontology/cybersecurity"/>

<owl:ObjectProperty rdf:about="#usesDevice">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="#Device"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#user_name">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#user_role">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#user_email">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#login_ip">
  <rdfs:domain rdf:resource="#Device"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#User">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Device">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#User_U001">
  <rdf:type rdf:resource="#User"/>
  <usesDevice rdf:resource="#Device_D001"/>
  <user_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">John Doe</user_name>
  <user_role rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Admin</user_role>
  <user_email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">john.doe@company.com</user_email>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Device_D001">
  <rdf:type rdf:resource="#Device"/>
  <login_ip rdf:datatype="http://www.w3.org/2001/XMLSchema#string">192.168.1.100</login_ip>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#User_U002">
  <rdf:type rdf:resource="#User"/>
  <usesDevice rdf:resource="#Device_D002"/>
  <user_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jane Smith</user_name>
  <user_role rdf:datatype="http://www.w3.org/2001/XMLSchema#string">User</user_role>
  <user_email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">jane.smith@company.com</user_email>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Device_D002">
  <rdf:type rdf:resource="#Device"/>
  <login_ip rdf:datatype="http://www.w3.org/2001/XMLSchema#string">192.168.1.101</login_ip>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#User_U003">
  <rdf:type rdf:resource="#User"/>
  <usesDevice rdf:resource="#Device_D003"/>
  <user_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob Wilson</user_name>
  <user_role rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Analyst</user_role>
  <user_email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bob.wilson@company.com</user_email>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Device_D003">
  <rdf:type rdf:resource="#Device"/>
  <login_ip rdf:datatype="http://www.w3.org/2001/XMLSchema#string">10.0.0.50</login_ip>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#User_U004">
  <rdf:type rdf:resource="#User"/>
  <usesDevice rdf:resource="#Device_D004"/>
  <user_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice Brown</user_name>
  <user_role rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manager</user_role>
  <user_email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">alice.brown@company.com</user_email>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Device_D004">
  <rdf:type rdf:resource="#Device"/>
  <login_ip rdf:datatype="http://www.w3.org/2001/XMLSchema#string">192.168.1.102</login_ip>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#User_U005">
  <rdf:type rdf:resource="#User"/>
  <usesDevice rdf:resource="#Device_D005"/>
  <user_name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Charlie Davis</user_name>
  <user_role rdf:datatype="http://www.w3.org/2001/XMLSchema#string">User</user_role>
  <user_email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">charlie.davis@company.com</user_email>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Device_D005">
  <rdf:type rdf:resource="#Device"/>
  <login_ip rdf:datatype="http://www.w3.org/2001/XMLSchema#string">10.0.0.51</login_ip>
</owl:NamedIndividual>


</rdf:RDF>
